# =============================================================================
# SIGTRP — variáveis de ambiente (Vercel / local)
# =============================================================================
# Copie para .env.local em desenvolvimento.
# Na Vercel: Project → Settings → Environment Variables
# =============================================================================

# --- Banco de dados (obrigatório) ---
# Use UMA das opções abaixo.

# Opção 1 (recomendada na Vercel): connection string do pooler Supabase
# Supabase → Project Settings → Database → Connection string → URI → Transaction pooler (porta 6543)
DATABASE_URL=postgresql://postgres.SEU_PROJECT_ID:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Opção 2: montagem automática pela aplicação (lib/db.ts)
# SUPABASE_PROJECT_ID=seu_project_id
# SUPABASE_DB_PASSWORD=sua_senha_do_banco
# SUPABASE_POOLER_HOST=aws-0-sa-east-1.pooler.supabase.com
