# Copie este arquivo para .env.local e preencha com os valores reais.
# No Windows: copy .env.example .env.local

# ── Supabase (projeto) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_PROJECT_ID=SEU_PROJECT_REF

# ── Chaves API Supabase ─────────────────────────────────────────────
# Settings → API → anon / service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Banco de dados (PostgreSQL via pooler) ──────────────────────────
# Settings → Database → Database password
# Use aspas se a senha tiver # ou outros caracteres especiais
SUPABASE_DB_PASSWORD=

# Settings → Database → Connection string → host do pooler
SUPABASE_POOLER_HOST=aws-0-sa-east-1.pooler.supabase.com

# Opcional: URL completa (se preenchida, tem prioridade)
DATABASE_URL=

# Opcional: session mode para migrations
DIRECT_URL=
